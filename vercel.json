{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/thien-hoang-kim build",
  "outputDirectory": "artifacts/thien-hoang-kim/dist/public",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
