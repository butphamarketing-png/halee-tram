{
  "installCommand": "pnpm install",
  "buildCommand": "node scripts/sync-vercel-api.mjs && pnpm --filter @workspace/thien-hoang-kim build",
  "outputDirectory": "artifacts/thien-hoang-kim/dist/public",
  "framework": null,
  "functions": {
    "api/bookings.ts": { "maxDuration": 30 },
    "api/admin/*.ts": { "maxDuration": 30 },
    "api/sitemap.xml.ts": { "maxDuration": 30 },
    "api/robots.txt.ts": { "maxDuration": 30 },
    "api/indexnow-verify.ts": { "maxDuration": 10 },
    "api/bot-render.ts": { "maxDuration": 30 },
    "api/llms.txt.ts": { "maxDuration": 15 }
  },
  "redirects": [
    {
      "source": "/tin-tuc/cham-soc-da-chan-tai-nha",
      "destination": "/tin-tuc/cha-got-chan-dinh-ky",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/api/robots.txt" },
    { "source": "/llms.txt", "destination": "/api/llms.txt" },
    { "source": "/favicon.ico", "destination": "/favicon.svg" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
