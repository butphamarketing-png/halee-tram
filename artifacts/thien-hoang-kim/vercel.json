{
  "installCommand": "cd ../.. && pnpm install --shamefully-hoist",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/thien-hoang-kim build",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024,
      "includeFiles": "server/**"
    }
  },
  "redirects": [
    {
      "source": "/tin-tuc/cham-soc-da-chan-tai-nha",
      "destination": "/tin-tuc/cha-got-chan-dinh-ky",
      "permanent": true
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/favicon.ico", "destination": "/favicon.svg" },
    { "source": "/adminbp", "destination": "/" },
    { "source": "/adminbp/:path*", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
