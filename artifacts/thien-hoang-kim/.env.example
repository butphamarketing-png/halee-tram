# Vite (build + client)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
VITE_ADMIN_BASE_PATH=/adminbp
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin123

# Vercel serverless (Settings → Environment Variables) — KHÔNG commit giá trị thật
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
ADMIN_USERNAME=admin
ADMIN_TOKEN=admin123

# Cloudflare R2 — kho ảnh/video (ưu tiên hơn Supabase Storage khi đủ biến)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=halee-tram-media
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev
R2_KEY_PREFIX=media

# Local dev only
PORT=23943
BASE_PATH=/
